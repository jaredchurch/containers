{
  "name": "Base Image Dev Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    // Installs and configures Docker inside your dev environment safely
    "ghcr.io/devcontainers/features/docker-in-docker:1": {
      "version": "latest",
      "moby": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker" // Gives you a visual Docker extension inside VS Code
      ]
    }
  }
}
